{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "."],
      "autoPort": true
    },
    {
      "name": "Static Site (http-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8080", "--cors"],
      "port": 8080
    }
  ]
}
